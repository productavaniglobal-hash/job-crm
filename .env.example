# Copy to .env.local and fill in values (never commit .env.local).

# Supabase (Project Settings → API)
# Use either the legacy anon key or the new publishable key from the dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# If your project shows a publishable key instead of "anon":
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only: required for admin scripts and service role operations (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Postgres — use session (direct) OR transaction pooler from dashboard (not both)
# Session: postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Pooler: postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
